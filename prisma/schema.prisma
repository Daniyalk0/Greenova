generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int           @id @default(autoincrement())
  name          String?
  email         String?       @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String        @default("customer")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  accounts      Account[]
  addresses     Address[]
  carts         Cart[]
  orders        Order[]
  reviews       Review?
  sessions      Session[]
  locations     UserLocation?
  wishlist      Wishlist[]
}

model Product {
  id               Int         @id @default(autoincrement())
  name             String
  slug             String      @unique
  subCategory      String?
  imageUrl         String
  calories         Float?
  fat              Float?
  sugar            Float?
  carbohydrates    Float?
  protein          Float?
  basePricePerKg   Float
  availableWeights Float[]
  rating           Float?
  discount         Float?
  description      String?
  inStock          Boolean     @default(true)
  isActive         Boolean     @default(true)
  isFeatured       Boolean     @default(false)
  category         Category
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @default(now()) @updatedAt
  season           Season      @default(ALL)
  carts            Cart[]
  orderItems       OrderItem[]
  wishlist         Wishlist[]
}

model Cart {
  id         Int      @id @default(autoincrement())
  userId     Int
  productId  Int
  weight     Float
  totalPrice Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId, weight])
}

model Wishlist {
  id        Int      @id @default(autoincrement())
  userId    Int
  productId Int
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model Order {
  id                Int           @id @default(autoincrement())
  userId            Int
  createdAt         DateTime      @default(now())
  total             Int
  addressId         Int?
  city              String
  name              String
  phone             String
  pincode           String
  state             String
  street            String
  razorpayOrderId   String?       @unique
  razorpayPaymentId String?
  status            OrderStatus   @default(PENDING)
  paymentType       PaymentMethod
  address           Address?      @relation(fields: [addressId], references: [id])
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  items             OrderItem[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id              Int     @id @default(autoincrement())
  orderId         Int
  productId       Int
  weight          Float
  discountPercent Int
  discountedPrice Int
  lineTotal       Int
  originalPrice   Int
  order           Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Address {
  id        Int      @id @default(autoincrement())
  userId    Int
  name      String
  phone     String
  street    String
  city      String
  state     String
  pincode   String
  country   String   @default("India")
  landmark  String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders    Order[]
  serviceStatus AreaStatus @default(UNAVAILABLE)
  

  @@index([userId])
}

model Account {
  id                Int     @id @default(autoincrement())
  userId            Int
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           Int      @id @default(autoincrement())
  sessionToken String   @unique
  userId       Int
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Review {
  id        String   @id @default(cuid())
  userId    Int      @unique
  userName  String
  rating    Int
  comment   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userImage String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserLocation {
  id        String   @id @default(uuid())
  userId    Int      @unique
  label     String?
  address   String
  lat       Float
  lng       Float
  city      String?
  state     String?
  pincode   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Banner {
  id            String   @id @default(cuid())
  title         String
  subtitle      String?
  badge         String?
  price         Float?
  originalPrice Float?
  discountText  String?
  cta           String   @default("Shop Now")
  linkUrl       String   @default("/collections/all")
  imageUrl      String   // URL from Cloudinary/AWS S3
  
  // Design / Colors (Stored as a JSON object to save columns)
  colors        Json?    // { text: "text-white", ctaBg: "bg-black" }

  // Admin Controls
  isActive      Boolean  @default(true) // Turn on/off without deleting
  sortOrder     Int      @default(0)    // For rearranging slides (1st, 2nd, 3rd)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

enum PaymentMethod {
  COD
  RAZORPAY
}

enum OrderStatus {
  PENDING
  PAID
  PLACED
  SHIPPED
  DELIVERED
  CANCELLED
  FAILED
}

enum Category {
  FRUITS
  VEGETABLES
}

enum Season {
  WINTER
  SUMMER
  MONSOON
  ALL
}


model ServiceArea {
  id        Int      @id @default(autoincrement())
  pincode   String   @unique
  city      String?
  state     String?
  status    AreaStatus @default(UNAVAILABLE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum AreaStatus {
  ACTIVE
  LIMITED
  UNAVAILABLE
}